# Copy to minuspod-mailer.env (or wherever your EnvironmentFile= points)
# and fill in your own values.

# Address to send FROM (must be acceptable to your SMTP relay)
MAIL_FROM=you@example.com

# Address to send TO
MAIL_TO=you@example.com

# SMTP relay host. If running as a rootless Podman container alongside
# MinusPod, host.containers.internal resolves to the host automatically.
SMTP_HOST=host.containers.internal
SMTP_PORT=25

# Port the mailer's HTTP server listens on inside the container
LISTEN_PORT=8080
